# Google OAuth（Google Cloud Console で取得）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# デプロイ環境推奨: Service Account JSON（期限切れしない）
# - GCPでサービスアカウント鍵(JSON)を作成し、中身をそのまま貼り付け
# - スプレッドシートを service account の client_email に共有（編集権限）
# GOOGLE_SERVICE_ACCOUNT_JSON=

# トークン保存先（省略時: credentials/tokens.json）
# GOOGLE_TOKENS_PATH=./credentials/tokens.json

# デプロイ環境用: トークンJSONを直接渡す場合（ローカルでは不要）
# GOOGLE_TOKENS_JSON=

# Google スプレッドシートID（URLの /d/XXXXX/edit の XXXXX 部分）
SPREADSHEET_ID=

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# 通知先LINEグループID
LINE_GROUP_ID=

# ダッシュボードURL（LINE通知のリンクに使用、省略時: http://localhost:3010）
# DASHBOARD_URL=http://localhost:3010

# サーバーポート（省略時: 3010）
# PORT=3010
